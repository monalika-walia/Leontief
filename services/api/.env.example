# Leontief API — copy to services/api/.env for local dev (never commit the real one).
DATABASE_URL=postgres://leontief:leontief@localhost:5432/leontief
PORT=8787
# Comma-separated landing origins allowed to POST the early-access form.
CORS_ORIGINS=http://localhost:8080,http://localhost:5173
# Set to a long random string in production so stored IP hashes aren't guessable.
IP_HASH_SALT=change-me-in-prod
