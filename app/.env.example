# Leontief dApp — copy to app/.env.local and fill from deploy.env (setup_testnet.sh).
# All VITE_-prefixed so Vite exposes them to the client. Contract IDs only — never
# secret keys here EXCEPT the throwaway testnet demo keys under VITE_DEMO_*.

VITE_RPC_URL=https://soroban-testnet.stellar.org
VITE_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
VITE_EXPLORER_BASE=https://stellar.expert/explorer/testnet

# Contracts (from deploy.env)
VITE_VAULT_FACTORY=
VITE_VAULT_LEOD=
VITE_ORACLE_ADAPTER=
VITE_MOCK_ORACLE=
VITE_MINI_POOL=
VITE_LEOD_SAC=
VITE_USDC_SAC=
VITE_LEOD_ASSET_ID=LEOD

# Demo mode (the /demo stepper). Testnet only; keys are throwaway.
VITE_DEMO_MODE=true
VITE_DEMO_ISSUER_SK=
VITE_DEMO_USER_SK=
VITE_DEMO_LIQUIDATOR_SK=
VITE_DEMO_RANDO_SK=
